<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Relatório de Resultados (RAR) - Equipe O</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">
    <!-- FontAwesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        burgundy: {
                            50: '#fdf2f4',
                            100: '#fce7f3',
                            500: '#800020',  /* Bordô principal */
                            600: '#6b001c',
                            700: '#540016',
                            950: '#2b0008',
                        },
                        navy: {
                            50: '#f0f4f8',
                            100: '#d9e2ec',
                            500: '#002040',  /* Azul Marinho clássico */
                            600: '#001a33',
                            700: '#001424',
                            900: '#030712',  /* Quase preto */
                        }
                    },
                    fontFamily: {
                        poppins: ['Poppins', 'sans-serif'],
                        sans: ['Open Sans', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        body {
            font-family: 'Open Sans', sans-serif;
            background-color: #f8fafc;
        }
        h1, h2, h3, h4, .font-poppins {
            font-family: 'Poppins', sans-serif;
        }
        .bg-burgundy-custom {
            background-color: #800020;
        }
        .text-burgundy {
            color: #800020;
        }
        .bg-navy-custom {
            background-color: #000080;
        }
        .text-navy {
            color: #000080;
        }
        .border-navy {
            border-color: #000080;
        }
        .tab-active {
            border-bottom: 3px solid #800020;
            color: #800020;
            background-color: rgba(128, 0, 32, 0.05);
        }
        .content-section {
            display: none;
        }
        .content-section.active {
            display: block;
            animation: fadeIn 0.4s ease-out;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }
        /* Table Styles */
        .data-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
        }
        .data-table th {
            background-color: #f1f5f9;
            text-align: left;
            padding: 12px 10px;
            font-weight: 700;
            color: #0f172a;
            border-bottom: 2px solid #e2e8f0;
        }
        .data-table td {
            padding: 11px 10px;
            border-bottom: 1px solid #e2e8f0;
            color: #334155;
        }
        .data-table tr:hover {
            background-color: #f1f5f9;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col text-slate-800">

    <!-- Cabeçalho / Navegação -->
    <header class="bg-white sticky top-0 z-50 shadow-sm border-b border-rose-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-20">
                <div class="flex-shrink-0 flex items-center gap-3">
                    <div class="bg-[#800020] w-11 h-11 rounded-xl flex items-center justify-center text-white font-poppins font-bold text-2xl shadow-md shadow-rose-900/10">O</div>
                    <div class="flex flex-col">
                        <span class="font-poppins font-bold text-lg text-slate-900 leading-none">Relatório Jurídico</span>
                        <span class="text-xs text-[#800020] mt-1 font-bold tracking-widest uppercase">RAR • EQUIPE O</span>
                    </div>
                </div>
                
                <!-- Desktop Nav -->
                <nav class="hidden lg:flex space-x-1 h-full items-center text-xs font-semibold uppercase tracking-wider">
                    <button onclick="showSection('visao-geral')" class="nav-btn tab-active px-3 py-7 transition-all duration-300 hover:text-[#800020]" id="btn-visao-geral">
                        <i class="fa-solid fa-chart-line mr-1.5"></i> Visão Geral
                    </button>
                    <button onclick="showSection('resultados')" class="nav-btn px-3 py-7 transition-all duration-300 hover:text-[#800020]" id="btn-resultados">
                        <i class="fa-solid fa-scale-balanced mr-1.5"></i> Resultados & Pauta
                    </button>
                    <button onclick="showSection('regionais')" class="nav-btn px-3 py-7 transition-all duration-300 hover:text-purple-600" id="btn-regionais">
                        <i class="fa-solid fa-earth-americas mr-1.5"></i> Base Ativa Regional
                    </button>
                    <button onclick="showSection('entradas')" class="nav-btn px-3 py-7 transition-all duration-300 hover:text-purple-600" id="btn-entradas">
                        <i class="fa-solid fa-folder-plus mr-1.5"></i> Entradas & Objetos
                    </button>
                    <button onclick="showSection('equipe')" class="nav-btn px-3 py-7 transition-all duration-300 hover:text-purple-600" id="btn-equipe">
                        <i class="fa-solid fa-users mr-1.5"></i> Equipe & Produtividade
                    </button>
                </nav>
                
                <!-- Mobile Menu Button -->
                <div class="lg:hidden">
                    <button onclick="toggleMobileMenu()" class="text-[#800020] p-2 focus:outline-none" aria-label="Menu principal">
                        <i class="fa-solid fa-bars text-2xl"></i>
                    </button>
                </div>
            </div>
        </div>
        
        <!-- Mobile Dropdown Menu -->
        <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-rose-100 px-4 py-3 space-y-2 shadow-inner">
            <button onclick="showSection('visao-geral'); toggleMobileMenu()" class="w-full text-left font-semibold text-xs uppercase py-2 px-3 rounded-lg hover:bg-rose-50 text-[#800020] block" id="mob-btn-visao-geral">Visão Geral</button>
            <button onclick="showSection('resultados'); toggleMobileMenu()" class="w-full text-left font-semibold text-xs uppercase py-2 px-3 rounded-lg hover:bg-rose-50 text-indigo-900 block" id="mob-btn-resultados">Resultados & Pauta</button>
            <button onclick="showSection('regionais'); toggleMobileMenu()" class="w-full text-left font-semibold text-xs uppercase py-2 px-3 rounded-lg hover:bg-rose-50 text-brand block" id="mob-btn-regionais">Base Ativa Regional</button>
            <button onclick="showSection('entradas'); toggleMobileMenu()" class="w-full text-left font-semibold text-xs uppercase py-2 px-3 rounded-lg hover:bg-sky-50 text-brand block" id="mob-btn-entradas">Entradas & Objetos</button>
            <button onclick="showSection('equipe'); toggleMobileMenu()" class="w-full text-left font-semibold text-xs uppercase py-2 px-3 rounded-lg hover:bg-sky-50 text-brand block" id="mob-btn-equipe">Equipe & Produtividade</button>
        </div>
    </header>

    <main class="flex-grow">
        
        <!-- SECÇÃO: VISÃO GERAL -->
        <section id="visao-geral" class="content-section active">
            <div class="bg-gradient-to-r from-[#000080] via-[#400010] to-[#800020] text-white py-14 shadow-md">
                <div class="max-w-7xl mx-auto px-4">
                    <div class="flex flex-wrap items-center justify-between gap-4">
                        <div>
                            <span class="bg-white/10 text-white text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full border border-white/20">Consolidado Mensal</span>
                            <h2 class="text-3xl md:text-4xl font-bold mt-2 font-poppins">RAR EQUIPE O</h2>
                        </div>
                        <div class="bg-white/5 backdrop-blur-md border border-white/10 rounded-xl p-4 text-center min-w-[200px]">
                            <span class="text-xs uppercase tracking-wider text-rose-200">Base Ativa Geral</span>
                            <p class="text-3xl font-bold text-white mt-1">33</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="max-w-7xl mx-auto px-4 py-10 space-y-8">
                
                <!-- Big Numbers Cards -->
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
                    <div class="bg-white p-5 rounded-2xl shadow-sm border-l-4 border-slate-900 transition-all hover:shadow-md">
                        <div class="flex justify-between items-start text-slate-400">
                            <span class="text-xs font-bold uppercase tracking-wider">Processos Encerrados</span>
                            <i class="fa-solid fa-box-archive text-slate-900 text-lg"></i>
                        </div>
                        <p class="text-3xl font-bold text-slate-900 mt-2">12</p>
                        <p class="text-xs text-slate-500 mt-1">Demandas finalizadas no período</p>
                    </div>
                    
                    <div class="bg-white p-5 rounded-2xl shadow-sm border-l-4 border-emerald-500 transition-all hover:shadow-md">
                        <div class="flex justify-between items-start text-emerald-400">
                            <span class="text-xs font-bold uppercase tracking-wider">Audiências Realizadas</span>
                            <i class="fa-solid fa-calendar-check text-emerald-600 text-lg"></i>
                        </div>
                        <p class="text-3xl font-bold text-slate-850 mt-2">4</p>
                        <p class="text-xs text-slate-500 mt-1">4 audiências executadas</p>
                    </div>

                    <div class="bg-white p-5 rounded-2xl shadow-sm border-l-4 border-[#800020] transition-all hover:shadow-md">
                        <div class="flex justify-between items-start text-rose-400">
                            <span class="text-xs font-bold uppercase tracking-wider">Novas Entradas</span>
                            <i class="fa-solid fa-folder-plus text-burgundy-custom text-lg"></i>
                        </div>
                        <p class="text-3xl font-bold text-slate-800 mt-2">4</p>
                        <p class="text-xs text-slate-500 mt-1">Processos distribuídos no mês</p>
                    </div>

                    <div class="bg-white p-5 rounded-2xl shadow-sm border-l-4 border-[#000080] transition-all hover:shadow-md">
                        <div class="flex justify-between items-start text-indigo-400">
                            <span class="text-xs font-bold uppercase tracking-wider">Relatórios Enviados</span>
                            <i class="fa-solid fa-file-invoice text-navy-custom text-lg"></i>
                        </div>
                        <p class="text-3xl font-bold text-slate-800 mt-2">1</p>
                        <p class="text-xs text-slate-500 mt-1">Relatórios de acompanhamento</p>
                    </div>
                </div>

                <!-- METAS CLIENTE & DESTAQUE -->
                <div class="grid md:grid-cols-3 gap-8">
                    <div class="md:col-span-2 bg-white p-6 md:p-8 rounded-2xl shadow-sm border border-slate-100">
                        <h3 class="font-bold text-slate-900 mb-6 flex items-center gap-2 text-lg">
                            <i class="fa-solid fa-bullseye text-burgundy-custom"></i> Resultado das Metas Cliente
                        </h3>
                        <div class="bg-rose-50/50 border border-rose-100 rounded-xl p-6 text-center">
                            <p class="text-slate-900 font-semibold text-lg">Não há metas estabelecidas ou pactuadas para este período.</p>
                            <span class="text-xs text-slate-500 block mt-2">Performance operacional mantida em conformidade com as diretrizes</span>
                        </div>
                    </div>
                    
                    <div class="bg-white p-6 md:p-8 rounded-2xl shadow-sm flex flex-col justify-center items-center text-center border-t-4 border-burgundy-500 border border-slate-100">
                        <div class="w-16 h-16 bg-rose-50 rounded-full flex items-center justify-center mb-4 border border-rose-100">
                            <i class="fa-regular fa-clock text-2xl text-burgundy-custom"></i>
                        </div>
                        <h3 class="text-3xl font-bold text-slate-900">0</h3>
                        <p class="text-slate-600 font-semibold text-sm mt-1">Pendências de Pauta</p>
                        <p class="text-xs text-slate-400 mt-2">Nenhuma pendência de pauta cadastrada</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- SECÇÃO: RESULTADOS E PAUTA -->
        <section id="resultados" class="content-section">
            <div class="bg-[#000080] text-white py-14 shadow-md">
                <div class="max-w-7xl mx-auto px-4">
                    <div class="flex flex-wrap items-center justify-between gap-4">
                        <div>
                            <h2 class="text-3xl md:text-4xl font-bold font-poppins">Resultados & Pauta</h2>
                            <p class="text-xs uppercase tracking-wider text-rose-200 mt-1">Detalhamento dos Encerramentos e Audiências</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="max-w-7xl mx-auto px-4 py-10 space-y-8">
                
                <div class="grid md:grid-cols-2 gap-8">
                    <!-- Detalhamento de Encerramentos -->
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
                        <h3 class="font-bold text-slate-900 mb-6 border-l-4 border-burgundy-500 pl-4 text-lg">Processos Encerrados (12)</h3>
                        <div class="space-y-4">
                            <div>
                                <div class="flex justify-between text-sm mb-1">
                                    <span class="font-medium text-slate-700">Improcedência</span>
                                    <span class="font-bold text-slate-900">6 (50,00%)</span>
                                </div>
                                <div class="w-full bg-slate-100 rounded-full h-2">
                                    <div class="bg-emerald-500 h-2 rounded-full" style="width: 50%"></div>
                                </div>
                            </div>
                            
                            <div>
                                <div class="flex justify-between text-sm mb-1">
                                    <span class="font-medium text-slate-700">Extinção sem resolução do mérito <span class="text-xs text-slate-400">(incl. ausência do autor e ilegitimidade)</span></span>
                                    <span class="font-bold text-slate-900">4 (33,33%)</span>
                                </div>
                                <div class="w-full bg-slate-100 rounded-full h-2">
                                    <div class="bg-blue-500 h-2 rounded-full" style="width: 33.33%"></div>
                                </div>
                            </div>

                            <div>
                                <div class="flex justify-between text-sm mb-1">
                                    <span class="font-medium text-slate-700">Procedência parcial</span>
                                    <span class="font-bold text-slate-900">1 (8,33%)</span>
                                </div>
                                <div class="w-full bg-slate-100 rounded-full h-2">
                                    <div class="bg-yellow-500 h-2 rounded-full" style="width: 8.33%"></div>
                                </div>
                            </div>

                            <div>
                                <div class="flex justify-between text-sm mb-1">
                                    <span class="font-medium text-slate-700">Acordo</span>
                                    <span class="font-bold text-slate-900">1 (8,33%)</span>
                                </div>
                                <div class="w-full bg-slate-100 rounded-full h-2">
                                    <div class="bg-rose-500 h-2 rounded-full" style="width: 8.33%"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Audiências e Relatórios -->
                    <div class="space-y-8">
                        <div class="bg-white rounded-2xl shadow-sm p-6 md:p-8 border border-slate-100">
                            <h3 class="font-bold text-slate-900 mb-6 border-b pb-4 flex justify-between items-center text-lg">
                                <span><i class="fa-solid fa-users-rectangle text-burgundy-custom mr-2"></i> Audiências Realizadas</span>
                                <span class="bg-rose-50 text-burgundy-custom text-xs font-bold px-3 py-1 rounded-full border border-rose-100">Total: 4</span>
                            </h3>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div class="bg-slate-50 p-4 rounded-xl border border-slate-150 text-center">
                                    <p class="text-[10px] text-slate-600 uppercase font-bold tracking-wider">Por Advogado</p>
                                    <p class="text-3xl font-bold text-slate-800">2</p>
                                </div>
                                <div class="bg-slate-50 p-4 rounded-xl border border-slate-150 text-center">
                                    <p class="text-[10px] text-slate-600 uppercase font-bold tracking-wider">Por Correspondente</p>
                                    <p class="text-3xl font-bold text-slate-800">2</p>
                                </div>
                            </div>
                        </div>

                        <!-- Relatório do Cliente -->
                        <div class="bg-white rounded-2xl shadow-sm p-6 md:p-8 border border-slate-100">
                            <h3 class="font-bold text-slate-900 mb-4 border-b pb-3 text-lg flex justify-between items-center">
                                <span><i class="fa-solid fa-file-circle-check text-burgundy-custom mr-2"></i> Relatórios do Cliente</span>
                                <span class="bg-blue-50 text-navy-custom text-xs font-bold px-3 py-1 rounded-full border border-blue-100">Enviados: 1</span>
                            </h3>
                            <div class="p-4 bg-slate-50 rounded-xl border border-slate-200">
                                <span class="text-xs uppercase font-bold text-[#800020] block mb-1">Tipo de Relatório Cadastrado</span>
                                <p class="text-sm font-semibold text-slate-700">Relatório “diário” de acompanhamento dos casos.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sustentação Oral -->
                <div class="bg-gradient-to-r from-navy-500 to-burgundy-500 text-white rounded-2xl p-6 md:p-8 shadow-md">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-center">
                        <div class="md:col-span-1">
                            <h4 class="font-bold text-lg mb-2"><i class="fa-solid fa-microphone text-rose-200 mr-2"></i> Sustentação Oral</h4>
                            <p class="text-xs text-rose-200/80">Monitoramento e ocorrências de sustentações orais no período</p>
                        </div>
                        <div class="md:col-span-2 grid grid-cols-2 gap-4">
                            <div class="bg-white/10 backdrop-blur-md rounded-xl p-3 border border-white/15 text-center">
                                <span class="text-xs text-rose-100">Correspondente</span>
                                <p class="text-xl font-bold">0</p>
                            </div>
                            <div class="bg-white/10 backdrop-blur-md rounded-xl p-3 border border-white/15 text-center">
                                <span class="text-xs text-rose-100">Advogado Interno</span>
                                <p class="text-xl font-bold">0</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Defesas e Robôs -->
                <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm flex flex-col md:flex-row justify-between items-center gap-4">
                    <div>
                        <h4 class="font-bold text-slate-900"><i class="fa-solid fa-shield text-[#800020] mr-2"></i> Peticionamento Automático / Defesas Automáticas</h4>
                        <p class="text-xs text-slate-500">Defesas feitas pela ENTER (ou plataforma semelhante)</p>
                    </div>
                    <span class="text-xl font-bold bg-slate-100 text-slate-800 px-5 py-2 rounded-xl border border-slate-200">0</span>
                </div>

            </div>
        </section>

        <!-- SECÇÃO: BASE ATIVA REGIONAL -->
        <section id="regionais" class="content-section">
            <div class="bg-[#800020] text-white py-14 shadow-md">
                <div class="max-w-7xl mx-auto px-4">
                    <h2 class="text-3xl md:text-4xl font-bold font-poppins">Base Ativa Regional</h2>
                    <p class="text-rose-100 text-sm mt-1">Análise territorial e controle de migrações processuais</p>
                </div>
            </div>
            
            <div class="max-w-7xl mx-auto px-4 py-10 space-y-8">
                
                <div class="bg-white rounded-2xl shadow-sm p-6 md:p-8 border border-slate-100 flex flex-wrap justify-between items-center gap-4">
                    <div>
                        <h3 class="font-bold text-slate-900 text-lg">Resumo de Carteira</h3>
                        <p class="text-xs text-slate-500 mt-0.5">Indicadores de migrações ocorridas no período de dados</p>
                    </div>
                    <div class="flex gap-4 sm:gap-6 flex-wrap">
                        <div class="text-center bg-rose-50 border border-rose-100 px-5 py-3 rounded-xl min-w-[130px]">
                            <span class="text-[10px] text-burgundy-custom uppercase font-bold tracking-wider block">Houve Migração?</span>
                            <p class="text-lg font-bold text-burgundy-custom mt-1">Sim (6 migrados)</p>
                        </div>
                        <div class="text-center bg-slate-100 border border-slate-200 px-5 py-3 rounded-xl min-w-[130px]">
                            <span class="text-[10px] text-slate-500 uppercase font-bold tracking-wider block">Base Ativa Original</span>
                            <p class="text-lg font-bold text-slate-800 mt-1">39</p>
                        </div>
                        <div class="text-center bg-navy-custom text-white px-5 py-3 rounded-xl shadow-sm min-w-[130px]">
                            <span class="text-[10px] text-rose-100 uppercase font-bold tracking-wider block">Base Líquida Geral</span>
                            <p class="text-lg font-bold mt-1">33</p>
                        </div>
                    </div>
                </div>

                <!-- Gráfico de Regiões de Base Ativa -->
                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6">
                    
                    <!-- SUDESTE: 12 -->
                    <div class="bg-white rounded-2xl shadow-sm overflow-hidden border border-slate-100 flex flex-col justify-between">
                        <div class="bg-navy-500 text-white px-4 py-3 font-semibold text-sm flex justify-between items-center">
                            <span>Sudeste</span>
                            <span class="bg-[#800020] text-white text-xs px-2.5 py-0.5 rounded-full font-bold">12</span>
                        </div>
                        <div class="p-4 space-y-3 text-xs flex-grow">
                            <div class="flex justify-between items-center text-slate-600">
                                <span>São Paulo</span>
                                <span class="font-bold text-slate-900">5</span>
                            </div>
                            <div class="flex justify-between items-center text-slate-600">
                                <span>Minas Gerais</span>
                                <span class="font-bold text-slate-900">3</span>
                            </div>
                            <div class="flex justify-between items-center text-slate-600">
                                <span>Rio de Janeiro</span>
                                <span class="font-bold text-slate-900">2</span>
                            </div>
                            <div class="flex justify-between items-center text-slate-600">
                                <span>Espírito Santo</span>
                                <span class="font-bold text-slate-900">3</span>
                            </div>
                        </div>
                    </div>

                    <!-- NORDESTE: 9 -->
                    <div class="bg-white rounded-2xl shadow-sm overflow-hidden border border-slate-100 flex flex-col justify-between">
                        <div class="bg-navy-500 text-white px-4 py-3 font-semibold text-sm flex justify-between items-center">
                            <span>Nordeste</span>
                            <span class="bg-[#800020] text-white text-xs px-2.5 py-0.5 rounded-full font-bold">9</span>
                        </div>
                        <div class="p-4 space-y-3 text-xs flex-grow">
                            <div class="flex justify-between items-center text-slate-600">
                                <span>Bahia</span>
                                <span class="font-bold text-slate-900">8</span>
                            </div>
                            <div class="flex justify-between items-center text-slate-600">
                                <span>Piauí</span>
                                <span class="font-bold text-slate-900">1</span>
                            </div>
                        </div>
                    </div>

                    <!-- NORTE: 6 -->
                    <div class="bg-white rounded-2xl shadow-sm overflow-hidden border border-slate-100 flex flex-col justify-between">
                        <div class="bg-navy-500 text-white px-4 py-3 font-semibold text-sm flex justify-between items-center">
                            <span>Norte</span>
                            <span class="bg-[#800020] text-white text-xs px-2.5 py-0.5 rounded-full font-bold">6</span>
                        </div>
                        <div class="p-4 space-y-3 text-xs flex-grow">
                            <div class="flex justify-between items-center text-slate-600">
                                <span>Amazonas</span>
                                <span class="font-bold text-slate-900">6</span>
                            </div>
                        </div>
                    </div>

                    <!-- CENTRO-OESTE: 4 -->
                    <div class="bg-white rounded-2xl shadow-sm overflow-hidden border border-slate-100 flex flex-col justify-between">
                        <div class="bg-navy-500 text-white px-4 py-3 font-semibold text-sm flex justify-between items-center">
                            <span>Centro-Oeste</span>
                            <span class="bg-[#800020] text-white text-xs px-2.5 py-0.5 rounded-full font-bold">4</span>
                        </div>
                        <div class="p-4 space-y-3 text-xs flex-grow">
                            <div class="flex justify-between items-center text-slate-600">
                                <span>Distrito Federal</span>
                                <span class="font-bold text-slate-900">2</span>
                            </div>
                            <div class="flex justify-between items-center text-slate-600">
                                <span>Goiás</span>
                                <span class="font-bold text-slate-900">1</span>
                            </div>
                        </div>
                    </div>

                    <!-- SUL: 1 -->
                    <div class="bg-white rounded-2xl shadow-sm overflow-hidden border border-slate-100 flex flex-col justify-between">
                        <div class="bg-navy-500 text-white px-4 py-3 font-semibold text-sm flex justify-between items-center">
                            <span>Sul</span>
                            <span class="bg-[#800020] text-white text-xs px-2.5 py-0.5 rounded-full font-bold">1</span>
                        </div>
                        <div class="p-4 space-y-3 text-xs flex-grow">
                            <div class="flex justify-between items-center text-slate-600">
                                <span>Santa Catarina</span>
                                <span class="font-bold text-slate-900">1</span>
                            </div>
                        </div>
                    </div>

                </div>

            </div>
        </section>

        <!-- SECÇÃO: ENTRADAS E OBJETOS -->
        <section id="entradas" class="content-section">
            <div class="bg-[#000080] text-white py-14 shadow-md">
                <div class="max-w-7xl mx-auto px-4">
                    <h2 class="text-3xl md:text-4xl font-bold font-poppins">Entradas & Objetos</h2>
                    <p class="text-rose-200 text-sm mt-1">Análise volumétrica de entradas por classificação de objetos no mês</p>
                </div>
            </div>
            
            <div class="max-w-7xl mx-auto px-4 py-10 space-y-8">
                
                <div class="bg-white rounded-2xl shadow-sm p-6 md:p-8 border border-slate-100">
                    <h3 class="font-bold text-slate-900 mb-6 border-b pb-4 flex justify-between items-center text-lg">
                        <span><i class="fa-solid fa-list-check text-burgundy-custom mr-2"></i> Distribuição Temática de Entradas</span>
                        <span class="bg-rose-50 text-burgundy-custom text-xs font-bold px-3 py-1 rounded-full border border-rose-100">Total: 4 Entradas</span>
                    </h3>
                    
                    <div class="space-y-6 max-w-3xl">
                        <div>
                            <div class="flex justify-between text-sm mb-1 font-semibold text-slate-700">
                                <span>Cancelamento</span>
                                <span>4 (100,00%)</span>
                            </div>
                            <div class="w-full bg-slate-100 rounded-full h-3">
                                <div class="bg-burgundy-custom h-3 rounded-full" style="width: 100%"></div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </section>

        <!-- SECÇÃO: EQUIPE E PRODUTIVIDADE -->
        <section id="equipe" class="content-section">
            <div class="bg-[#800020] text-white py-14 shadow-md">
                <div class="max-w-7xl mx-auto px-4">
                    <h2 class="text-3xl md:text-4xl font-bold font-poppins">Equipe & Produtividade</h2>
                    <p class="text-rose-100 text-sm mt-1">Métricas de performance operacional e fluxo da equipe</p>
                </div>
            </div>

            <div class="max-w-7xl mx-auto px-4 py-10 space-y-8">
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <!-- Produtividade Geral -->
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 md:col-span-2">
                        <h3 class="font-bold text-slate-900 mb-4 border-b pb-3 flex items-center justify-between">
                            <span>Produtividade da Equipe Geral</span>
                            <span class="text-xs text-slate-400 uppercase font-semibold">Atividades</span>
                        </h3>
                        <div class="overflow-x-auto">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>Advogado (ADV)</th>
                                        <th>Compromissos Realizados</th>
                                        <th>Prazos Cumpridos</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td class="font-bold text-slate-900 flex items-center gap-2 py-4">
                                            <div class="w-8 h-8 bg-navy-500 text-white rounded-full flex items-center justify-center font-bold text-xs">K</div>
                                            KALINE
                                        </td>
                                        <td class="font-semibold text-slate-700">53</td>
                                        <td class="font-semibold text-slate-700">19</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Dados Operacionais de Recessos -->
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
                        <h3 class="font-bold text-slate-900 mb-4 border-b pb-3 flex items-center justify-between">
                            <span>Licenças & Recessos</span>
                            <span class="text-xs text-slate-400 uppercase font-semibold">Controle</span>
                        </h3>
                        <div class="space-y-4 text-sm mt-6">
                            <div class="flex justify-between items-center p-3 bg-slate-50 rounded-xl">
                                <span class="font-semibold text-slate-600">Total de Recessos</span>
                                <span class="bg-[#800020] text-white px-3 py-1 rounded-lg font-bold text-xs">0</span>
                            </div>
                            <div class="text-center p-4 border border-dashed border-slate-300 rounded-xl bg-slate-50">
                                <p class="text-xs text-slate-500 font-semibold leading-relaxed">Não houve afastamentos, recessos cadastrados ou substituições temporárias no período avaliado.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Organograma da Equipe -->
                <div class="bg-white p-6 md:p-8 rounded-2xl shadow-sm border-t-4 border-burgundy-500 border border-slate-100">
                    <h3 class="font-bold text-slate-900 mb-6 uppercase tracking-wider text-sm flex items-center gap-2">
                        <i class="fa-solid fa-sitemap text-burgundy-custom"></i> Estrutura do Organograma Operacional
                    </h3>
                    
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
                        <div class="p-4 bg-slate-50 rounded-xl border border-slate-150">
                            <span class="text-[10px] text-slate-400 uppercase font-bold tracking-wider">Coordenação do Time / Liderança</span>
                            <p class="text-sm font-bold text-slate-500 mt-1">Não há</p>
                        </div>
                        <div class="p-4 bg-rose-50 rounded-xl border border-rose-100">
                            <span class="text-[10px] text-slate-700 uppercase font-bold tracking-wider">Estratégico</span>
                            <p class="text-sm font-bold text-burgundy-600 mt-1">MFSA (Marina)</p>
                        </div>
                        <div class="p-4 bg-rose-50 rounded-xl border border-rose-100">
                            <span class="text-[10px] text-slate-700 uppercase font-bold tracking-wider">Operação</span>
                            <p class="text-sm font-bold text-burgundy-600 mt-1">MFSA (Marina)</p>
                        </div>
                    </div>

                    <!-- Turnover e Treinamentos -->
                    <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-6 text-sm">
                        <div class="bg-slate-50 p-5 rounded-xl border border-slate-200">
                            <span class="font-bold text-slate-900 block mb-2"><i class="fa-solid fa-right-from-bracket mr-1.5"></i> Turnover:</span>
                            <p class="text-slate-600 text-xs">Total: 0</p>
                        </div>
                        <div class="bg-slate-50 p-5 rounded-xl border border-slate-200">
                            <span class="font-bold text-slate-700 block mb-2"><i class="fa-solid fa-user-plus mr-1.5"></i> Pessoas em Treinamento:</span>
                            <p class="text-slate-600 text-xs">Total: 0 (Nenhum novato em fase de integração)</p>
                        </div>
                    </div>
                </div>

            </div>
        </section>

    </main>

    <footer class="bg-white border-t border-slate-200 py-8 mt-12">
        <div class="max-w-7xl mx-auto px-4 text-center text-slate-500 text-xs tracking-wider font-semibold uppercase">
            <p>&copy; Relatório de Resultados Jurídicos — Equipe O</p>
        </div>
    </footer>

    <script>
        function showSection(sectionId) {
            // Esconde todas as secções
            document.querySelectorAll('.content-section').forEach(section => {
                section.classList.remove('active');
            });
            
            // Mostra a secção alvo
            const target = document.getElementById(sectionId);
            if (target) {
                target.classList.add('active');
            }

            // Atualiza os estilos das abas (Desktop)
            document.querySelectorAll('.nav-btn').forEach(btn => {
                btn.classList.remove('tab-active');
            });
            const activeBtn = document.getElementById('btn-' + sectionId);
            if (activeBtn) {
                activeBtn.classList.add('tab-active');
            }

            // Atualiza os estilos das abas (Mobile)
            document.querySelectorAll('[id^="mob-btn-"]').forEach(btn => {
                btn.classList.remove('bg-rose-50', 'font-bold');
            });
            const activeMobBtn = document.getElementById('mob-btn-' + sectionId);
            if (activeMobBtn) {
                activeMobBtn.classList.add('bg-rose-50', 'font-bold');
            }

            // Rola suavemente para o topo
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function toggleMobileMenu() {
            const menu = document.getElementById('mobile-menu');
            if (menu.classList.contains('hidden')) {
                menu.classList.remove('hidden');
            } else {
                menu.classList.add('hidden');
            }
        }
    </script>
</body>
</html>
